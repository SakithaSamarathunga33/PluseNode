{
	admin localhost:2019
}

{$CADDY_SITE_ADDRESS} {
	# Compress everything except streaming endpoints
	@compressible not path /events /ws /api/ws/*
	encode @compressible gzip

	handle_path /go/* {
		reverse_proxy go-api:4002 {
			flush_interval -1
		}
	}

	handle /events {
		reverse_proxy go-api:4002 {
			flush_interval -1
		}
	}

	handle /ws {
		reverse_proxy go-api:4002
	}

	handle /health {
		reverse_proxy go-api:4002
	}

	handle {
		reverse_proxy web:3000
	}
}

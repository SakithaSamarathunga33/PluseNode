{"nodes": [{"id": "specs_2026_05_24_login_system_design_login_system", "label": "PulseNode Login System", "file_type": "document", "source_file": "/home/sakitha/apps/vps/docs/superpowers/specs/2026-05-24-login-system-design.md", "source_location": "line 1", "source_url": null, "captured_at": "2026-05-24", "author": null, "contributor": null}, {"id": "specs_2026_05_24_login_system_design_single_admin_auth", "label": "Single-Admin Optional Authentication", "file_type": "concept", "source_file": "/home/sakitha/apps/vps/docs/superpowers/specs/2026-05-24-login-system-design.md", "source_location": "line 3", "source_url": null, "captured_at": "2026-05-24", "author": null, "contributor": null, "rationale": "Entirely opt-in design: if no admin account exists, the dashboard is fully open (backward compatible). Single admin row pattern keeps auth simple and matches self-hosted single-user use case."}, {"id": "specs_2026_05_24_login_system_design_httonly_jwt_cookie", "label": "httpOnly JWT Session Cookie (pn_session)", "file_type": "concept", "source_file": "/home/sakitha/apps/vps/docs/superpowers/specs/2026-05-24-login-system-design.md", "source_location": "line 5", "source_url": null, "captured_at": "2026-05-24", "author": null, "contributor": null, "rationale": "httpOnly + SameSite=Lax prevents JS-based token theft. 30-minute sliding window balances session security with usability."}, {"id": "specs_2026_05_24_login_system_design_users_table", "label": "users SQLite table", "file_type": "concept", "source_file": "/home/sakitha/apps/vps/docs/superpowers/specs/2026-05-24-login-system-design.md", "source_location": "line 15", "source_url": null, "captured_at": "2026-05-24", "author": null, "contributor": null}, {"id": "specs_2026_05_24_login_system_design_bcrypt", "label": "bcrypt Password Hashing (cost 12)", "file_type": "concept", "source_file": "/home/sakitha/apps/vps/docs/superpowers/specs/2026-05-24-login-system-design.md", "source_location": "line 147", "source_url": null
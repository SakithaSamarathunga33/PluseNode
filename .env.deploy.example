# Copy this file to .env on your VPS before running docker compose.

# Public URL where users open the frontend.
NEXT_PUBLIC_ORIGIN=http://YOUR_VPS_IP:3000

# Browser-facing API URLs. Use your domain/IP here, not localhost, unless browsing on the VPS itself.
NEXT_PUBLIC_NODE_API=http://YOUR_VPS_IP:4001
NEXT_PUBLIC_PYTHON_API=http://YOUR_VPS_IP:8001
NEXT_PUBLIC_WS_URL=ws://YOUR_VPS_IP:4001

# Published host ports.
WEB_PORT=3000
NODE_PORT=4001
PYTHON_PORT=8001

# Set this to true only after adding frontend Bearer-token auth.
NODE_API_AUTH=false
NODE_API_SECRET=replace-with-a-long-random-secret

# Optional Coolify API integration.
COOLIFY_API_URL=
COOLIFY_API_TOKEN=

# Optional Postgres introspection. Leave empty to use mock database cards.
DATABASE_URL=

# PulseNode — environment template
# Copy this file to .env.local and fill in your values.

# ── Public URLs ────────────────────────────────────────────────────────────────
# The Go API is the single backend — set to your VPS IP or domain.
NEXT_PUBLIC_ORIGIN=http://YOUR_VPS_IP
NEXT_PUBLIC_API=http://YOUR_VPS_IP
NEXT_PUBLIC_SSE_URL=http://YOUR_VPS_IP/api/sse

# ── Internal port bindings ─────────────────────────────────────────────────────
WEB_PORT=127.0.0.1:3000
GO_PORT=127.0.0.1:4001

# ── API security ───────────────────────────────────────────────────────────────
# Set API_AUTH=true and a strong secret to require a bearer token on all /api routes.
API_AUTH=false
API_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── Optional: Coolify integration ──────────────────────────────────────────────
COOLIFY_API_URL=
COOLIFY_API_TOKEN=

# ── Optional: VPS display label ────────────────────────────────────────────────
VPS_REGION=

# ── Build version tag (injected automatically by deploy.sh) ───────────────────
PULSENODE_VERSION=dev

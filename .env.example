# PulseNode — environment template
# Run ./deploy.sh for an interactive setup, or copy this file to .env.local and fill in manually.

# ── Public URLs ────────────────────────────────────────────────────────────────
# Set these to your VPS IP or domain.
# The same value is used for all three because Nginx routes each path internally.
NEXT_PUBLIC_ORIGIN=http://YOUR_VPS_IP
NEXT_PUBLIC_NODE_API=http://YOUR_VPS_IP
NEXT_PUBLIC_PYTHON_API=http://YOUR_VPS_IP
NEXT_PUBLIC_WS_URL=ws://YOUR_VPS_IP

# ── Internal port bindings ─────────────────────────────────────────────────────
# Bound to localhost so only Nginx (or Traefik) can reach them from outside.
WEB_PORT=127.0.0.1:3000
NODE_PORT=127.0.0.1:4001
PYTHON_PORT=127.0.0.1:8001

# ── API security ───────────────────────────────────────────────────────────────
# Set NODE_API_AUTH=true and a strong secret to require a bearer token on all /api routes.
NODE_API_AUTH=false
NODE_API_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── Optional: Coolify integration ──────────────────────────────────────────────
# Enables the Coolify tab to show real projects, apps, and deployments.
COOLIFY_API_URL=
COOLIFY_API_TOKEN=

# ── Optional: PostgreSQL introspection ─────────────────────────────────────────
# Enables real table sizes, row counts, and slow-query data in the Databases tab.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# PulseNode — environment template
# Run ./deploy.sh for an interactive setup, or copy this file to .env.local and fill in manually.

# ── Public URL ─────────────────────────────────────────────────────────────────
# Set this to your VPS IP or domain. Caddy routes internally.
NEXT_PUBLIC_ORIGIN=http://YOUR_VPS_IP
NEXT_PUBLIC_GO_API=http://YOUR_VPS_IP/go
CADDY_SITE_ADDRESS=:80

# ── Internal port bindings ─────────────────────────────────────────────────────
# Bound to localhost so only Caddy (or Traefik) can reach them from outside.
WEB_PORT=127.0.0.1:3000
GO_PORT=127.0.0.1:4002

# ── API security ───────────────────────────────────────────────────────────────
# Set GO_API_AUTH=true and a strong secret to require a bearer token on all /api routes.
GO_API_AUTH=false
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
AES_KEY=change-me-generate-with-openssl-rand-hex-32
MASTER_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Optional: Coolify integration ──────────────────────────────────────────────
# Enables the Coolify tab to show real projects, apps, and deployments.
COOLIFY_API_URL=
COOLIFY_API_TOKEN=

# ── Optional: PostgreSQL introspection ─────────────────────────────────────────
# Enables real table sizes, row counts, and slow-query data in the Databases tab.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=
